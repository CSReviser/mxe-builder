QString extractLevel(const QString &rawTitle)
{
    // 空白正規化
    QString title = rawTitle;
    title.replace(QChar(0x3000), QChar(' '));
    title = title.simplified();

    // constants の編なし語を QStringList に変換
    QStringList baseWords;
    for (int i = 0; i < constants::LEVEL_WORDS_COUNT; ++i) {
        baseWords << QString::fromUtf8(constants::LEVEL_WORDS[i]);
    }

    // title の先頭から「XX編」を探す
    for (const QString &base : baseWords) {
        QString withHen = base + "編";

        // title の中で最初に出てくる「XX編」を採用
        int pos = title.indexOf(withHen, 0, Qt::CaseInsensitive);
        if (pos >= 0) {
            return withHen;   // 最初に見つかった XX編 を返す
        }
    }

    return QString();
}



