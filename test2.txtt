QString normalizeSpaces(const QString &raw)
{
    QString s = raw;
    s.replace(QChar(0x3000), QChar(' ')); // 全角→半角
    return s.simplified();                // 連続空白を1つに
}

QString extractLevel(const QString &rawTitle)
{
    const QString title = normalizeSpaces(rawTitle);

    // 将来「上級編」などが増えてもここに追加するだけ
    static const QStringList levelWords = {
        "入門編",
        "初級編",
        "中級編",
        "応用編"
    };

    // 「まいにち○○語 XX編」だけを対象にする正規表現
    // 例: まいにちイタリア語 初級編
    QRegularExpression re(
        R"(まいにち[^\s]+語\s*(入門編|初級編|中級編|応用編))",
        QRegularExpression::CaseInsensitiveOption
    );

    QRegularExpressionMatch m = re.match(title);
    if (!m.hasMatch())
        return QString();

    const QString level = m.captured(1);

    // 念のため語彙チェック（将来の拡張に備える）
    if (levelWords.contains(level, Qt::CaseInsensitive))
        return level;

    return QString();
}






static QString buildCommandString(const QString& program, const QStringList& args)
{
    QStringList escaped;

    for (const QString& arg : args) {
        // スペース対策
        if (arg.contains(' ') || arg.contains('"')) {
            QString a = arg;
            a.replace("\"", "\\\"");
            escaped << "\"" + a + "\"";
        } else {
            escaped << arg;
        }
    }

    return program + " " + escaped.join(" ");
}

