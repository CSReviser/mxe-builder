static QStringList levelWords()
{
    return {
        QString::fromUtf8(constants::LEVEL_NYUMON),
        QString::fromUtf8(constants::LEVEL_SHOKYU),
        QString::fromUtf8(constants::LEVEL_CHUKYU),
        QString::fromUtf8(constants::LEVEL_OYO)
    };
}

QString buildLevelRegexPattern()
{
    QStringList escaped;

    for (const QString &w : levelWords()) {
        escaped << QRegularExpression::escape(w);
    }

    // (入門編|初級編|中級編|応用編) の形を動的生成
    return "(" + escaped.join("|") + ")";
}

QString extractLevel(const QString &rawTitle)
{
    QString title = rawTitle;
    title.replace(QChar(0x3000), QChar(' '));
    title = title.simplified();

