
void RecordingCore::run()
{
    auto result = m_runner.run(plan);

    if (result.canceled || m_cancelRequested) {
        emit messageGenerated("キャンセルされました");
    }

    emit finished();
}

void RecordingCore::cancel()
{
    m_cancelRequested = true;
    m_runner.requestCancel();   // ★ これだけで効く
}








