QString Settings::iniFilePath()
{
#if defined(Q_OS_WIN)
    // Windows: exe と同じ場所
    QString dir = QCoreApplication::applicationDirPath();
    return dir + QDir::separator() + Constants::IniFileName;

#elif defined(Q_OS_LINUX)
    // Linux: AppImage を含めて「実行ファイルの実体がある場所」
    char exePath[PATH_MAX] = {0};
    ssize_t len = readlink("/proc/self/exe", exePath, sizeof(exePath) - 1);

    QString dir;
    if (len > 0) {
        QFileInfo fi(QString::fromLocal8Bit(exePath));
        dir = fi.absolutePath();
    } else {
        // fallback（通常の Linux 実行時）
        dir = QCoreApplication::applicationDirPath();
    }

    return dir + QDir::separator() + Constants::IniFileName;

#elif defined(Q_OS_MACOS)
    // macOS: app bundle 内は書き込み不可
    // → OS 標準の設定保存場所を使う
    QString dir = QStandardPaths::writableLocation(QStandardPaths::AppConfigLocation);
    QDir().mkpath(dir);
    return dir + QDir::separator() + Constants::IniFileName;

#else
    // その他 OS
    QString dir = QCoreApplication::applicationDirPath();
    return dir + QDir::separator() + Constants::IniFileName;
#endif
}

#ifdef Q_OS_LINUX
    // AppImage 実行時は APPIMAGE 環境変数がセットされる
    QString appImagePath = qgetenv("APPIMAGE");
    if (!appImagePath.isEmpty()) {
        QFileInfo fi(appImagePath);
        QString basePath = fi.absolutePath();
        return basePath + QDir::separator() + Constants::IniFileName;
    }

    // 通常の Linux 実行時
    return QCoreApplication::applicationDirPath()
           + QDir::separator()
           + Constants::IniFileName;
#endif



QString Settings::iniFilePath()
{
#ifdef Q_OS_LINUX
    // AppImage の場合、applicationDirPath() は squashfs を指すため使えない
    // 実行ファイルの実体パスを /proc/self/exe から取得する
    char exePath[PATH_MAX] = {0};
    ssize_t len = readlink("/proc/self/exe", exePath, sizeof(exePath) - 1);

    QString dir;
    if (len > 0) {
        QString realExe = QString::fromLocal8Bit(exePath);
        QFileInfo fi(realExe);
        dir = fi.absolutePath();  // AppImage の外側の実行ファイルパス
    } else {
        // fallback（通常の Linux 実行時）
        dir = QCoreApplication::applicationDirPath();
    }

    return dir + QDir::separator() + Constants::IniFileName;

#else
    // macOS / Windows は従来通り
    QString dir = QCoreApplication::applicationDirPath();
    return dir + QDir::separator() + Constants::IniFileName;
#endif
}



/* QComboBox 本体 */
QComboBox {
    background-color: transparent;   /* または希望の色 */
    color: #ffffff;                  /* 文字色（ダークモード想定） */
    border: 1px solid #555555;
    padding: 4px;
}

/* ポップアップメニュー全体（これが重要！） */
QComboBox QAbstractItemView {
    background-color: transparent;     /* または親の背景に合わせたい色 */
    color: #ffffff;                    /* 通常の項目文字色 */
    border: 1px solid #666666;
    selection-background-color: #3a3a3a;   /* 選択時の背景（ダークモード向け） */
    selection-color: #ffffff;              /* 選択時の文字色 */
}

/* 項目ごとのスタイル（必要に応じて） */
QComboBox QAbstractItemView::item {
    padding: 6px 8px;
    background-color: transparent;
}

/* 選択中の項目（ホバー含む） */
QComboBox QAbstractItemView::item:selected,
QComboBox QAbstractItemView::item:hover {
    background-color: #505050;   /* 好みの濃いグレーなどに調整 */
    color: #ffffff;
}


QComboBox {
    /* これを追加するとMac独自のポップアップ形式ではなくなり、QSSが効くようになります */
    combobox-popup: 0;
    
    background-color: white;
    color: black;
}

/* リスト全体の基本色 */
#popup_ext QAbstractItemView {
    background-color: darkslategray;
    color: white;
}

/* 選択（ハイライト）された時の色を明示 */
#popup_ext QAbstractItemView:item:selected {
    background-color: #4A90E2; /* 選択中の青色など */
    color: white;
}

/* マウスが乗っている時（hover）も指定するとより確実 */
#popup_ext QAbstractItemView:item:hover {
    background-color: #4A90E2;
    color: white;
}



