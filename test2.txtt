void RecordingCore::execute(const RecordingRequest& req)
{
    // ===== ① コマンド生成 =====
    FfmpegCommandBuilder builder;

    QString program = "ffmpeg";
    QStringList args = builder.build(req);

    // ===== ② Runner =====
    FfmpegRunner runner;

    runner.setLogCallback([this](const QString& msg) {
        emit messageGenerated(msg); // or CLI出力
    });

    // ===== ③ 実行 =====
    auto result = runner.run(
        program,
        args,
        3,          // retry
        1000,       // base delay
        30000       // idle timeout
    );

    // ===== ④ 結果処理 =====
    if (result.success) {
        emit finished(true);
    } else if (result.canceled) {
        emit canceled();
    } else {
        emit finished(false);
    }
}


static QString normalizeExtension(const QString& ext)
{
    if (ext.startsWith("mp3"))
        return "mp3";

    if (ext.startsWith("m4a"))
        return "m4a";

    if (ext.startsWith("aac"))
        return "aac";

    return ext;
}

