    QProcess* m_process = nullptr;
};

void FfmpegRunner::run(const QStringList& args)
{
    m_process = new QProcess;

    m_process->start("ffmpeg", args);
    m_process->waitForFinished(-1);

    delete m_process;
    m_process = nullptr;
}

void FfmpegRunner::cancel()
{
    if (m_process) {
        m_process->kill();   // or terminate()
    }
}

