    QString inputUrl;

    QString rawTitle;
    QString kouza;

    QDate date;
    QTime time;

    QString nendo;
    QString fileId;
    QString thumbnailPath;

    QString dupnmb;

    bool isXml = false;  // 🔥 追加
};






