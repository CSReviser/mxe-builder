    removeFileForce(tempPath);   // ★ 既存removeを置換
    outLog += "\n[timeout]";
    return -3;
}

bool removeFileForce(const QString& path)
{
    for (int i = 0; i < 10; ++i) {

        if (!QFile::exists(path))
            return true;

        if (QFile::remove(path))
            return true;

        QThread::msleep(50);
    }

    return false;
}




