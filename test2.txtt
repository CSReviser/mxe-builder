    // まいにち○○語 の直後だけを対象にする
    QString pattern = QStringLiteral(R"(まいにち[^\s]+語\s*)") + levelPattern;

    QRegularExpression re(pattern, QRegularExpression::CaseInsensitiveOption);
    QRegularExpressionMatch m = re.match(title);

    if (!m.hasMatch())
        return QString();

    return m.captured(1);  // 最初の XX編
}

